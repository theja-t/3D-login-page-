<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>3D Background Login Page</title>
  <style>
    /* Reset & Base */
    * {
      margin: 0;
      padding: 0;
      box-sizing: border-box;
      font-family: Arial, sans-serif;
    }

    body {
      height: 100vh;
      display: flex;
      justify-content: center;
      align-items: center;
      background: #0f2027;
      background: linear-gradient(135deg, #2c5364, #203a43, #0f2027);
      overflow: hidden;
      color: #fff;
    }

    /* 3D cube container */
    .background {
      position: absolute;
      top: 0; left: 0;
      width: 100%; height: 100%;
      overflow: hidden;
      z-index: 0;
      perspective: 1000px;
    }

    .cube {
      position: absolute;
      width: 40px;
      height: 40px;
      background: rgba(255, 255, 255, 0.1);
      border: 1px solid rgba(255, 255, 255, 0.2);
      animation: float 20s infinite linear;
      transform-style: preserve-3d;
    }

    /* Create multiple cubes with different positions */
    .cube:nth-child(1) { top: 20%; left: 10%; animation-duration: 18s; }
    .cube:nth-child(2) { top: 70%; left: 25%; animation-duration: 22s; }
    .cube:nth-child(3) { top: 40%; left: 80%; animation-duration: 26s; }
    .cube:nth-child(4) { top: 60%; left: 50%; animation-duration: 20s; }
    .cube:nth-child(5) { top: 10%; left: 70%; animation-duration: 24s; }

    @keyframes float {
      0%   { transform: rotateX(0) rotateY(0) translateZ(0); }
      50%  { transform: rotateX(180deg) rotateY(180deg) translateZ(200px); }
      100% { transform: rotateX(360deg) rotateY(360deg) translateZ(0); }
    }

    /* Login Box */
    .login-container {
      position: relative;
      z-index: 1;
      background: rgba(0, 0, 0, 0.6);
      padding: 40px;
      border-radius: 12px;
      box-shadow: 0 8px 25px rgba(0,0,0,0.5);
      width: 320px;
      backdrop-filter: blur(6px);
    }

    .login-container h1 {
      text-align: center;
      margin-bottom: 25px;
      font-size: 24px;
    }

    .login-container label {
      display: block;
      font-size: 14px;
      margin-bottom: 6px;
    }

    .login-container input {
      width: 100%;
      padding: 10px;
      margin-bottom: 20px;
      border: none;
      border-radius: 6px;
      background: rgba(255,255,255,0.1);
      color: #fff;
      outline: none;
    }

    .login-container input::placeholder {
      color: rgba(255,255,255,0.7);
    }

    .login-container button {
      width: 100%;
      padding: 12px;
      border: none;
      border-radius: 6px;
      background: #00c6ff;
      background: linear-gradient(135deg, #0072ff, #00c6ff);
      color: #fff;
      font-size: 16px;
      font-weight: bold;
      cursor: pointer;
      transition: 0.3s;
    }

    .login-container button:hover {
      opacity: 0.9;
    }

    .login-container .extra {
      text-align: center;
      margin-top: 15px;
      font-size: 13px;
    }

    .login-container .extra a {
      color: #00c6ff;
      text-decoration: none;
    }

    @media (max-width: 400px) {
      .login-container {
        width: 90%;
        padding: 25px;
      }
    }
  </style>
</head>
<body>
  <!-- 3D Background -->
  <div class="background">
    <div class="cube"></div>
    <div class="cube"></div>
    <div class="cube"></div>
    <div class="cube"></div>
    <div class="cube"></div>
  </div>

  <!-- Login Form -->
  <div class="login-container" role="form" aria-label="Login Form">
    <h1>Welcome Back</h1>
    <form>
      <label for="username">Username</label>
      <input type="text" id="username" placeholder="Enter username" required aria-required="true">
      
      <label for="password">Password</label>
      <input type="password" id="password" placeholder="Enter password" required aria-required="true">
      
      <button type="submit">Login</button>
      
      <div class="extra">
        <p><a href="#">Forgot Password?</a></p>
        <p>Don’t have an account? <a href="#">Sign up</a></p>
      </div>
    </form>
  </div>
</body>
</html>
